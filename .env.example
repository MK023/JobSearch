# === Required ===
ANTHROPIC_API_KEY=your-api-key-here

# === Database ===
# Replace USER, PASSWORD, DB with your own values — do NOT commit real creds.
DATABASE_URL=postgresql://USER:PASSWORD@db:5432/DB
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=replace_me

# === Cache (optional, app works without it) ===
REDIS_URL=redis://redis:6379/0

# === Authentication ===
SECRET_KEY=change-me-to-a-random-string
ADMIN_EMAIL=admin@jobsearch.local
ADMIN_PASSWORD=changeme

# === Security ===
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80
TRUSTED_HOSTS=localhost,backend

# === Email notifications (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=marco.bellingeri@gmail.com
FOLLOWUP_REMINDER_DAYS=5

# === Sentry (error tracking, optional) ===
SENTRY_DSN=

# === RapidAPI (Glassdoor, Salary Data, News) ===
RAPIDAPI_KEY=

# === Cloudflare R2 (file upload) ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=jobsearch-files

# === Resend (document reminder emails) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jobsearches.cc
DOCUMENT_REMINDER_EMAIL=marco.bellingeri@gmail.com
