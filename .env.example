# === Required ===
ANTHROPIC_API_KEY=your-api-key-here

# === Database ===
DATABASE_URL=postgresql://jobsearch:jobsearch@db:5432/jobsearch
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=jobsearch
POSTGRES_DB=jobsearch

# === Cache (optional, app works without it) ===
REDIS_URL=redis://redis:6379/0

# === Authentication ===
SECRET_KEY=change-me-to-a-random-string
ADMIN_EMAIL=admin@jobsearch.local
ADMIN_PASSWORD=changeme

# === Security ===
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80
TRUSTED_HOSTS=localhost,backend

# === Email notifications (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=marco.bellingeri@gmail.com
FOLLOWUP_REMINDER_DAYS=5

# === Glassdoor company data (optional, RapidAPI - company-data12) ===
RAPIDAPI_KEY=

# === Cloudflare R2 (file upload) ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=jobsearch-files

# === Resend (document reminder emails) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jobsearches.cc
DOCUMENT_REMINDER_EMAIL=marco.bellingeri@gmail.com
